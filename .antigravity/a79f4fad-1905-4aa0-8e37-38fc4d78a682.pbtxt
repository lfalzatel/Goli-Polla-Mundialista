    replacement_chunks {
      target_content: "export default function ReglasTab() {\n  return (\n    <div className=\"space-y-6\">\n      \n      {/* Rules Header introduction */}\n      <section className=\"space-y-2\">\n        <h2 className=\"font-display text-4xl text-[#b1c6f9] uppercase tracking-wider mb-2\">\n          Reglamento Oficial\n        </h2>\n        <p className=\"text-[#c5c6d0] font-sans text-base max-w-2xl leading-relaxed\">\n          Domina el campo de juego conociendo el sistema de puntuaci\303\263n. La precisi\303\263n es la clave fundamental para llegar a la cima de la tabla del grupo.\n        </p>\n      </section>\n\n      {/* Bento Layout Grid for official regulations */}\n      <div className=\"grid grid-cols-1 md:grid-cols-12 gap-6\">\n        \n        {/* Scoring list card */}\n        <div className=\"md:col-span-8 bg-[#1f1f23] border border-white/5 p-6 rounded-2xl relative overflow-hidden shadow-xl\">\n          <div className=\"absolute top-4 right-4 opacity-[0.03]\">\n            <span className=\"material-symbols-outlined text-[140px]\" style={{ fontVariationSettings: \"\'FILL\' 0\" }}>\n              sports_soccer\n            </span>\n          </div>\n\n          <h3 className=\"font-display text-2xl text-[#b1c6f9] mb-5 flex items-center gap-2 tracking-wide uppercase\">\n            <span className=\"material-symbols-outlined text-[22px] text-[#ffe16d]\">scoreboard</span>\n            Puntuaci\303\263n por Partido\n          </h3>\n\n          <div className=\"space-y-4\">\n            \n            {/* Exact marcador row */}\n            <div className=\"flex justify-between items-center p-4 bg-[#192f59]/30 rounded-xl border-l-4 border-[#2ff801]\">\n              <div>\n                <p className=\"font-display text-lg text-[#e3e2e6] tracking-wide\">Marcador Exacto</p>\n                <p className=\"text-[#c5c6d0] text-xs font-sans mt-0.5\">Acierto total y absoluto de goles de ambos equipos</p>\n              </div>\n              <div className=\"flex items-center gap-2 shrink-0\">\n                <span className=\"font-display text-4xl text-[#79ff5b] font-bold\">5</span>\n                <span className=\"font-mono text-xs text-[#79ff5b]\">PTS</span>\n              </div>\n            </div>\n\n            {/* Winner + goals row */}\n            <div className=\"flex justify-between items-center p-4 bg-[#1b1b1f] rounded-xl border-l-4 border-[#b1c6f9]\">\n              <div>\n                <p className=\"font-display text-lg text-[#e3e2e6] tracking-wide\">Ganador + Goles</p>\n                <p className=\"text-[#c5c6d0] text-xs font-sans mt-0.5\">Acierto de ganador y cantidad de goles correctos de un equipo</p>\n              </div>\n              <div className=\"flex items-center gap-2 shrink-0\">\n                <span className=\"font-display text-4xl text-[#b1c6f9] font-bold\">3</span>\n                <span className=\"font-mono text-xs text-[#b1c6f9]\">PTS</span>\n              </div>\n            </div>\n\n            {/* Winner only row */}\n            <div className=\"flex justify-between items-center p-4 bg-[#1b1b1f] rounded-xl border-l-4 border-[#8e9099]\">\n              <div>\n                <p className=\"font-display text-lg text-[#e3e2e6] tracking-wide\">Ganador</p>\n                <p className=\"text-[#c5c6d0] text-xs font-sans mt-0.5\">Acierto de tendencia de victoria o empate (sin goles exactos)</p>\n              </div>\n              <div className=\"flex items-center gap-2 shrink-0\">\n                <span className=\"font-display text-4xl text-[#8e9099] font-bold\">2</span>\n                <span className=\"font-mono text-xs text-[#8e9099]\">PTS</span>\n              </div>\n            </div>\n\n          </div>\n        </div>\n\n        {/* Phases summary timeline card */}\n        <div className=\"md:col-span-4 bg-[#1f1f23] border border-[#b1c6f9]/10 p-6 rounded-2xl flex flex-col justify-between shadow-xl\">\n          <div>\n            <h3 className=\"font-display text-2xl text-[#b1c6f9] mb-4 flex items-center gap-2 tracking-wide uppercase\">\n              <span className=\"material-symbols-outlined text-[22px] text-[#b1c6f9]\">account_tree</span>\n              Fases del Torneo\n            </h3>\n            <p className=\"text-[#c5c6d0] font-sans text-xs sm:text-sm leading-relaxed mb-6\">\n              El torneo se divide en dos fases cr\303\255ticas. Tus predicciones de la Fase 1 deben completarse antes del partido inaugural.\n            </p>\n\n            <ul className=\"space-y-4\">\n              <li className=\"flex gap-3\">\n                <div className=\"w-8 h-8 rounded bg-[#192f59] flex items-center justify-center shrink-0 border border-[#b1c6f9]/20\">\n                  <span className=\"font-mono font-bold text-xs text-[#b1c6f9]\">01</span>\n                </div>\n                <div>\n                  <p className=\"font-sans font-bold text-sm text-[#e3e2e6]\">Fase de Grupos</p>\n                  <p className=\"text-xs text-[#c5c6d0]\">Predicci\303\263n de todos los encuentros de las rondas iniciales.</p>\n                </div>\n              </li>\n              <li className=\"flex gap-3\">\n                <div className=\"w-8 h-8 rounded bg-[#ffe16d]/10 flex items-center justify-center shrink-0 border border-[#ffe16d]/20\">\n                  <span className=\"font-mono font-bold text-xs text-[#ffe16d]\">02</span>\n                </div>\n                <div>\n                  <p className=\"font-sans font-bold text-sm text-[#e3e2e6]\">Eliminatorias</p>\n                  <p className=\"text-xs text-[#c5c6d0]\">Predicciones en play-offs, llaves y bonificaciones adicionales.</p>\n                </div>\n              </li>\n            </ul>\n          </div>\n\n          <div className=\"mt-6 pt-4 border-t border-white/5\">\n            <div className=\"flex items-center gap-2 text-[#ffb4ab]\">\n              <span className=\"material-symbols-outlined text-sm\">info</span>\n              <span className=\"font-mono text-[10px] uppercase font-bold tracking-wider\">\n                CIERRE DE APUESTAS: 1H ANTES DEL PARTIDO\n              </span>\n            </div>\n          </div>\n        </div>\n\n        {/* Global Special Tournament Picks (Phase 2 Booster) */}\n        <div className=\"md:col-span-12 bg-[#1f1f23] border border-white/5 p-6 rounded-2xl shadow-xl\">\n          <h3 className=\"font-display text-2xl text-[#ffe16d] mb-5 flex items-center gap-2 uppercase tracking-wide\">\n            <span className=\"material-symbols-outlined text-[24px]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n              workspace_premium\n            </span>\n            Bonificaciones Especiales (Fase 2)\n          </h3>\n\n          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">\n            \n            {/* Champion */}\n            <div className=\"bg-[#292a2d] p-4 rounded-xl flex items-center justify-between border border-white/5 hover:border-[#ffe16d]/50 transition-all\">\n              <div className=\"flex items-center gap-3\">\n                <span className=\"material-symbols-outlined text-[#ffe16d]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                  trophy\n                </span>\n                <span className=\"font-sans font-bold text-[#e3e2e6] text-sm\">Campe\303\263n</span>\n              </div>\n              <div className=\"flex items-center gap-1\">\n                <span className=\"font-display text-2xl text-[#ffe16d] font-bold\">+20</span>\n                <span className=\"font-mono text-[10px] text-[#ffe16d]\">PTS</span>\n              </div>\n            </div>\n\n            {/* Top Scorer */}\n            <div className=\"bg-[#292a2d] p-4 rounded-xl flex items-center justify-between border border-white/5 hover:border-[#b1c6f9]/50 transition-all\">\n              <div className=\"flex items-center gap-3\">\n                <span className=\"material-symbols-outlined text-[#b1c6f9]\