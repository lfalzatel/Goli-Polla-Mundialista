    replacement_infos {
      original_chunk {
        target_content: "export default function Header({ usuario, onLogout, onChangeGroup }: HeaderProps) {\n  const [showDropdown, setShowDropdown] = useState(false);\n\n  return (\n    <header className=\"fixed top-0 left-0 w-full z-50 bg-[#1b1b1f] border-b border-white/10 shadow-sm flex justify-between items-center px-4 py-2.5\">\n      {/* Profil capsule and title */}\n      <div className=\"flex items-center gap-3\">\n        <button \n          onClick={() => setShowDropdown(!showDropdown)}\n          className=\"relative w-10 h-10 rounded-full overflow-hidden border border-[#b1c6f9]/30 hover:border-[#79ff5b] transition-all cursor-pointer\"\n          aria-haspopup=\"true\"\n          aria-expanded={showDropdown}\n        >\n          {usuario.foto ? (\n            <img \n              alt={usuario.nombre} \n              className=\"w-full h-full object-cover\" \n              src={usuario.foto} \n              referrerPolicy=\"no-referrer\"\n            />\n          ) : (\n            <div className=\"w-full h-full bg-[#192f59] flex items-center justify-center text-[#b1c6f9] font-bold\">\n              {usuario.nombre.substring(0, 2).toUpperCase()}\n            </div>\n          )}\n        </button>\n        <div>\n          <span className=\"font-mono text-[9px] text-[#79ff5b] block tracking-widest uppercase leading-none mb-1\">\n            GRUPO {usuario.codigoGrupo || \'FOE\'}\n          </span>\n          <h1 className=\"font-display text-2xl tracking-wider text-[#b1c6f9] leading-none select-none\">\n            POLLA MUNDIALISTA FOE\n          </h1>\n        </div>\n      </div>\n\n      {/* Points indicator cap with dropdown */}\n      <div className=\"relative\">\n        <button\n          onClick={() => setShowDropdown(!showDropdown)}\n          className=\"flex items-center gap-1 bg-[#121316] hover:bg-[#292a2d] px-3 py-1.5 rounded-full border border-white/5 font-sans cursor-pointer text-xs md:text-sm transition-all\"\n        >\n          <span className=\"text-[#c5c6d0] font-medium font-sans\">Mis Puntos: </span>\n          <span className=\"text-[#79ff5b] font-bold font-mono\">\n            {usuario.puntosTotal} pts\n          </span>\n          <span className=\"material-symbols-outlined text-[#b1c6f9] text-[20px] transition-transform duration-200\" style={{ transform: showDropdown ? \'rotate(180deg)\' : \'rotate(0)\' }}>\n            arrow_drop_down\n          </span>\n        </button>\n\n        {/* Dropdown Menu block */}\n        {showDropdown && (\n          <div className=\"absolute right-0 mt-2 w-56 bg-[#1f1f23] border border-white/10 rounded-xl shadow-2xl py-2 z-50 animate-in fade-in slide-in-from-top-3 duration-200\">\n            <div className=\"px-4 py-2 border-b border-white/5\">\n              <p className=\"font-sans text-sm font-bold text-[#e3e2e6] truncate\">\n                {usuario.nombre}\n              </p>\n              <p className=\"font-mono text-[10px] text-[#8e9099] truncate\">\n                {usuario.email}\n              </p>\n            </div>\n            \n            <div className=\"p-1\">\n              <button\n                onClick={() => {\n                  setShowDropdown(false);\n                  onChangeGroup();\n                }}\n                className=\"w-full flex items-center gap-3 px-3 py-2 text-sm text-[#e3e2e6] hover:bg-white/5 rounded-lg transition-colors cursor-pointer text-left\"\n              >\n                <span className=\"material-symbols-outlined text-[#b1c6f9] text-[18px]\">\n                  group_work\n                </span>\n                <span className=\"font-sans\">Cambiar Grupo</span>\n              </button>\n\n              <button\n                onClick={() => {\n                  setShowDropdown(false);\n                  alert(\'Opciones de Configuraci\303\263n local guardadas.\');\n                }}\n                className=\"w-full flex items-center gap-3 px-3 py-2 text-sm text-[#e3e2e6] hover:bg-white/5 rounded-lg transition-colors cursor-pointer text-left\"\n              >\n                <span className=\"material-symbols-outlined text-[#b1c6f9] text-[18px]\">\n                  settings\n                </span>\n                <span className=\"font-sans\">Configuraci\303\263n</span>\n              </button>\n\n              <div className=\"h-[1px] bg-white/5 my-1\" />\n\n              <button\n                onClick={() => {\n                  setShowDropdown(false);\n                  onLogout();\n                }}\n                className=\"w-full flex items-center gap-3 px-3 py-2 text-sm text-red-400 hover:bg-red-500/10 rounded-lg transition-colors cursor-pointer text-left\"\n              >\n                <span className=\"material-symbols-outlined text-[18px]\">\n                  logout\n                </span>\n                <span className=\"font-sans font-medium\">Cerrar Sesi\303\263n</span>\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n    </header>\n  );\n}"
        replacement_content: "export default function Header({ usuario, onLogout, onChangeGroup }: HeaderProps) {\n  const [showDropdown, setShowDropdown] = useState(false);\n\n  return (\n    <header className=\"fixed top-0 left-0 w-full z-50 bg-[#034226] text-white border-b-4 border-[#e1b12c] shadow-md flex justify-between items-center px-4 h-16 shrink-0\">\n      {/* Profil capsule and title */}\n      <div className=\"flex items-center gap-3\">\n        <button \n          onClick={() => setShowDropdown(!showDropdown)}\n          className=\"relative w-10 h-10 rounded-full overflow-hidden border-2 border-[#e1b12c] hover:scale-105 transition-all cursor-pointer bg-white\"\n          aria-haspopup=\"true\"\n          aria-expanded={showDropdown}\n        >\n          {usuario.foto ? (\n            <img \n              alt={usuario.nombre} \n              className=\"w-full h-full object-cover\" \n              src={usuario.foto} \n              referrerPolicy=\"no-referrer\"\n            />\n          ) : (\n            <div className=\"w-full h-full bg-[#034226] flex items-center justify-center text-white font-bold\">\n              {usuario.nombre.substring(0, 2).toUpperCase()}\n            </div>\n          )}\n        </button>\n        <div>\n          <span className=\"font-mono text-[9px] text-[#e1b12c] block tracking-widest uppercase leading-none font-bold\">\n            GRUPO {usuario.codigoGrupo || \'FOE\'}\n          </span>\n          <h1 className=\"font-display text-2xl tracking-wider text-white leading-none select-none uppercase\">\n            POLLA MUNDIALISTA <span className=\"text-[#e1b12c]\">FOE</span>\n          </h1>\n        </div>\n      </div>\n\n      {/* Points indicator cap with dropdown */}\n      <div className=\"relative\">\n        <button\n          onClick={() => setShowDropdown(!showDropdown)}\n          className=\"flex items-center gap-1.5 bg-[#02331d] hover:bg-[#012213] px-3.5 py-1.5 rounded-full border border-white/20 font-sans cursor-pointer text-xs md:text-sm transition-all shadow-inner\"\n        >\n          <span className=\"text-white/80 font-medium font-sans\">Puntaje Total: </span>\n          <span className=\"text-[#e1b12c] font-bold font-mono text-sm\">\n            {usuario.puntosTotal} pts\n          </span>\n          <span className=\"material-symbols-outlined text-[#e1b12c] text-[20px] transition-transform duration-200\" style={{ transform: showDropdown ? \'rotate(180deg)\' : \'rotate(0)\' }}>\n            arrow_drop_down\n          </span>\n        </button>\n\n        {/* Dropdown Menu block in professional light design */}\n        {showDropdown && (\n          <div className=\"absolute right-0 mt-2 w-56 bg-white border border-slate-200 rounded-xl shadow-2xl py-2 z-50 animate-in fade-in slide-in-from-top-3 duration-200 text-slate-800\">\n            <div className=\"px-4 py-2 border-b border-slate-100\">\n              <p className=\"font-sans text-sm font-bold text-slate-800 truncate\">\n                {usuario.nombre}\n              </p>\n              <p className=\"font-mono text-[10px] text-slate-500 truncate\">\n                {usuario.email}\n              </p>\n            </div>\n            \n            <div className=\"p-1\">\n              <button\n                onClick={() => {\n                  setShowDropdown(false);\n                  onChangeGroup();\n                }}\n                className=\"w-full flex items-center gap-3 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-slate-950 rounded-lg transition-colors cursor-pointer text-left\"\n              >\n                <span className=\"material-symbols-outlined text-[#034226] text-[18px]\">\n                  group_work\n                </span>\n                <span className=\"font-sans font-medium\">Cambiar de Grupo</span>\n              </button>\n\n              <button\n                onClick={() => {\n                  setShowDropdown(false);\n                  // Dynamic subtle toast instead of raw blocking window.alert\n                  const toast = document.createElement(\'div\');\n                  toast.className = \'fixed top-4 left-1/2 -translate-x-1/2 bg-[#034226] text-white px-4 py-2.5 rounded-xl shadow-lg text-xs font-semibold z-50 transition-all transform scale-90 duration-300\';\n                  toast.textContent = \'Configuraciones locales sincronizadas\';\n                  document.body.appendChild(toast);\n                  setTimeout(() => toast.style.transform = \'translateY(10px) scale(1)\', 10);\n                  setTimeout(() => {\n                    toast.style.opacity = \'0\';\n                    setTimeout(() => toast.remove(), 300);\n                  }, 2000);\n                }}\n                className=\"w-full flex items-center gap-3 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50 hover:text-slate-950 rounded-lg transition-colors cursor-pointer text-left\"\n              >\n                <span className=\"material-symbols-outlined text-[#034226] text-[18px]\">\n                  settings\n                </span>\n                <span className=\"font-sans font-medium\">Configuraci\303\263n</span>\n              </button>\n\n              <div className=\"h-[1px] bg-slate-100 my-1\" />\n\n              <button\n                onClick={() => {\n                  setShowDropdown(false);\n                  onLogout();\n                }}\n                className=\"w-full flex items-center gap-3 px-3 py-2 text-sm text-red-600 hover:bg-red-50 rounded-lg transition-colors cursor-pointer text-left\"\n              >\n                <span className=\"material-symbols-outlined text-[18px]\">\n                  logout\n                </span>\n                <span className=\"font-sans font-bold\">Cerrar Sesi\303\263n</span>\n              </button>\n            </div>\n          </div>\n        )}\n      </div>\n    </header>\n  );\n}"
      }
