  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect } from \'react\';\nimport { Partido, Apuesta, RankedUser, Usuario } from \'./types\';\nimport { PARTIDOS_INICIALES, RANKING_INICIAL, APUESTAS_INICIALES_PRESETS, calcularPuntosPartido } from \'./data\';\nimport SplashLogin from \'./components/SplashLogin\';\nimport Header from \'./components/Header\';\nimport InicioTab from \'./components/InicioTab\';\nimport ReglasTab from \'./components/ReglasTab\';\nimport PerfilTab from \'./components/PerfilTab\';\n\nexport default function App() {\n  const [usuario, setUsuario] = useState<Usuario | null>(null);\n  const [partidos, setPartidos] = useState<Partido[]>(PARTIDOS_INICIALES);\n  const [apuestas, setApuestas] = useState<Apuesta[]>([]);\n  const [rankingLideres, setRankingLideres] = useState<RankedUser[]>(RANKING_INICIAL);\n  const [activeTab, setActiveTab] = useState<\'inicio\' | \'reglas\' | \'perfil\'>(\'inicio\');\n  const [showFloatingRanking, setShowFloatingRanking] = useState(false);\n\n  // Load configuration from LocalStorage on mount\n  useEffect(() => {\n    const savedUser = localStorage.getItem(\'polla_usuario\');\n    const savedPartidos = localStorage.getItem(\'polla_partidos\');\n    const savedApuestas = localStorage.getItem(\'polla_apuestas\');\n    const savedLideres = localStorage.getItem(\'polla_lideres\');\n\n    if (savedUser) {\n      setUsuario(JSON.parse(savedUser));\n    }\n    if (savedPartidos) {\n      setPartidos(JSON.parse(savedPartidos));\n    } else {\n      setPartidos(PARTIDOS_INICIALES);\n    }\n    if (savedApuestas) {\n      setApuestas(JSON.parse(savedApuestas));\n    } else {\n      // Initialize with default predictions\n      const initialApuestas: Apuesta[] = APUESTAS_INICIALES_PRESETS.map(preset => ({\n        id: preset.id,\n        uid: preset.uid,\n        partidoId: preset.partidoId,\n        golesLocalApuesta: preset.golesLocalApuesta,\n        golesVisitanteApuesta: preset.golesVisitanteApuesta,\n        equipoGanadorApuesta: preset.equipoGanadorApuesta,\n        puntosObtenidos: preset.puntosObtenidos,\n        bloqueada: preset.bloqueada\n      }));\n      setApuestas(initialApuestas);\n      localStorage.setItem(\'polla_apuestas\', JSON.stringify(initialApuestas));\n    }\n    if (savedLideres) {\n      setRankingLideres(JSON.parse(savedLideres));\n    } else {\n      setRankingLideres(RANKING_INICIAL);\n    }\n  }, []);\n\n  // Sync state functions\n  const handleLoginSuccess = (nombre: string, email: string, whatsapp: string, codigoGrupo: string) => {\n    const newUser: Usuario = {\n      uid: \'me\',\n      nombre,\n      email,\n      foto: \'https://lh3.googleusercontent.com/aida-public/AB6AXuB51HhLfnZaDiGtKYp7MwISidlkzLIvjuKRkqP-Z4Ht2dfgJK3G8Ve2q4QdXolTh7pung4KkLRXjVW-wEb_4UESxWciOP6HrVq2_JhM1XYhDssQTl7p5-ey-rgv2tfQCzfManWqd5WgZ8rShV-0IJFalxgyqdM5DuGNi-aMWPgI2fDBTcvn1bDgPNRX6YlC9MMlGEC_qv3OozOdRzTAWf5n3njxyzJz_10pMEEW1tGZ9t6OAaoy2zhSTVl1dQ10KnYavNUUhU2_0RU\',\n      whatsapp,\n      codigoGrupo,\n      puntosTotal: 125, // Default pre-calculated score from Screenshots\n      createdAt: new Date().toISOString()\n    };\n    \n    setUsuario(newUser);\n    localStorage.setItem(\'polla_usuario\', JSON.stringify(newUser));\n\n    // Force recalculating scores based on any final matches initially loaded\n    recalcularPuntosGlobalesYRanking(newUser, apuestas, partidos);\n  };\n\n  const handleLogout = () => {\n    localStorage.removeItem(\'polla_usuario\');\n    localStorage.removeItem(\'polla_partidos\');\n    localStorage.removeItem(\'polla_apuestas\');\n    localStorage.removeItem(\'polla_lideres\');\n    setUsuario(null);\n    setPartidos(PARTIDOS_INICIALES);\n    setApuestas([]);\n    setRankingLideres(RANKING_INICIAL);\n    setActiveTab(\'inicio\');\n  };\n\n  const handleChangeGroup = () => {\n    const newGroup = prompt(\'Ingresa el nuevo c\303\263digo de acceso de grupo:\', usuario?.codigoGrupo || \'\');\n    if (newGroup && newGroup.trim() && usuario) {\n      const updatedUser = { ...usuario, codigoGrupo: newGroup.toUpperCase() };\n      setUsuario(updatedUser);\n      localStorage.setItem(\'polla_usuario\', JSON.stringify(updatedUser));\n    }\n  };\n\n  const handleUpdateWhatsapp = (newPhone: string) => {\n    if (usuario) {\n      const updatedUser = { ...usuario, whatsapp: newPhone };\n      setUsuario(updatedUser);\n      localStorage.setItem(\'polla_usuario\', JSON.stringify(updatedUser));\n    }\n  };\n\n  const handleGuardarApuesta = (partidoId: string, golesLocal: number, golesVisitante: number) => {\n    if (!usuario) return;\n\n    const key = `${usuario.uid}_${partidoId}`;\n    const targetMatch = partidos.find(p => p.partidoId === partidoId);\n    \n    let originalApuestas = [...apuestas];\n    const index = originalApuestas.findIndex(a => a.id === key);\n\n    const calcPuntaje = targetMatch && targetMatch.estado === \'finalizado\' && targetMatch.golesLocal !== null && targetMatch.golesVisitante !== null\n      ? calcularPuntosPartido(targetMatch.golesLocal, targetMatch.golesVisitante, golesLocal, golesVisitante)\n      : 0;\n\n    const localApuesta: Apuesta = {\n      id: key,\n      uid: usuario.uid,\n      partidoId,\n      golesLocalApuesta: golesLocal,\n      golesVisitanteApuesta: golesVisitante,\n      equipoGanadorApuesta: golesLocal > golesVisitante ? \'local\' : golesLocal < golesVisitante ? \'visitante\' : \'empate\',\n      puntosObtenidos: calcPuntaje,\n      bloqueada: targetMatch ? (targetMatch.estado === \'finalizado\' || targetMatch.estado === \'en_vivo\') : false\n    };\n\n    if (index >= 0) {\n      originalApuestas[index] = localApuesta;\n    } else {\n      originalApuestas.push(localApuesta);\n    }\n\n    setApuestas(originalApuestas);\n    localStorage.setItem(\'polla_apuestas\', JSON.stringify(originalApuestas));\n\n    // Refresh overall user points\n    recalcularPuntosGlobalesYRanking(usuario, originalApuestas, partidos);\n  };\n\n  // Perform overall score updates when live match status transitions\n  const recalcularPuntosGlobalesYRanking = (currentUser: Usuario, currentApuestas: Apuesta[], currentPartidos: Partido[]) => {\n    let basePuntos = 120; // Simulated points from historic historical games in backend\n\n    currentApuestas.forEach(ap => {\n      const match = currentPartidos.find(p => p.partidoId === ap.partidoId);\n      if (match && match.estado === \'finalizado\' && match.golesLocal !== null && match.golesVisitante !== null) {\n        const pt = calcularPuntosPartido(\n          match.golesLocal, \n          match.golesVisitante, \n          ap.golesLocalApuesta, \n          ap.golesVisitanteApuesta\n        );\n        basePuntos += pt;\n      }\n    });\n\n    const updatedUser = { ...currentUser, puntosTotal: basePuntos };\n    setUsuario(updatedUser);\n    localStorage.setItem(\'polla_usuario\', JSON.stringify(updatedUser));\n\n    // Update group leaderboard dynamically\n    const updatedRanking = RANKING_INICIAL.map(leader => {\n      if (leader.uid === \'me\') {\n        return { ...leader, puntosTotal: basePuntos };\n      }\n      return leader;\n    }).sort((a, b) => b.puntosTotal - a.puntosTotal);\n\n    // Adjust rankings output indices\n    const updatedRankingWithPos = updatedRanking.map((item, idx) => ({\n      ...item,\n      posicion: idx + 1\n    }));\n\n    setRankingLideres(updatedRankingWithPos);\n    localStorage.setItem(\'polla_lideres\', JSON.stringify(updatedRankingWithPos));\n  };\n\n  // Simulate schedule cloud function matches finalized\n  const handleSimularPartidos = (resultados: Record<string, { golesLocal: number; golesVisitante: number }>) => {\n    if (!usuario) return;\n\n    // Transition matches status to finalized and write scores\n    const updatedPartidos = partidos.map(match => {\n      if (resultados[match.partidoId]) {\n        return {\n          ...match,\n          golesLocal: resultados[match.partidoId].golesLocal,\n          golesVisitante: resultados[match.partidoId].golesVisitante,\n          estado: \'finalizado\' as const\n        };\n      }\n      return match;\n    });\n\n    setPartidos(updatedPartidos);\n    localStorage.setItem(\'polla_partidos\', JSON.stringify(updatedPartidos));\n\n    // Recalculate bets points with the newly final scores\n    const updatedApuestas = apuestas.map(ap => {\n      const matchResult = resultados[ap.partidoId];\n      if (matchResult) {\n        const pts = calcularPuntosPartido(\n          matchResult.golesLocal,\n          matchResult.golesVisitante,\n          ap.golesLocalApuesta,\n          ap.golesVisitanteApuesta\n        );\n        return {\n          ...ap,\n          puntosObtenidos: pts,\n          bloqueada: true\n        };\n      }\n      return ap;\n    });\n\n    setApuestas(updatedApuestas);\n    localStorage.setItem(\'polla_apuestas\', JSON.stringify(updatedApuestas));\n\n    // Recalculate users standings\n    recalcularPuntosGlobalesYRanking(usuario, updatedApuestas, updatedPartidos);\n  };\n\n  // If the user isn\'t logged in, show the Splash and Google sign-in\n  if (!usuario) {\n    return <SplashLogin onLoginSuccess={handleLoginSuccess} />;\n  }\n\n  return (\n    <div className=\"min-h-screen bg-[#121316] text-[#e3e2e6] pb-28 pt-20\">\n      \n      {/* Background aesthetics layer */}\n      <div className=\"fixed inset-0 -z-10 bg-gradient-to-tr from-[#121316] via-[#0d0e11] to-[#001b44]/20\"></div>\n      <div className=\"fixed inset-0 -z-10 stadium-mesh opacity-30\"></div>\n\n      {/* Main navigation header */}\n      <Header \n        usuario={usuario} \n        onLogout={handleLogout} \n        onChangeGroup={handleChangeGroup} \n      />\n\n      {/* Active Tab rendering layout viewport */}\n      <main className=\"max-w-4xl mx-auto px-4 py-4 sm:py-6\">\n        {activeTab === \'inicio\' && (\n          <InicioTab \n            partidos={partidos} \n            apuestas={apuestas} \n            onGuardarApuesta={handleGuardarApuesta}\n            onSimularPartidos={handleSimularPartidos}\n          />\n        )}\n\n        {activeTab === \'reglas\' && (\n          <ReglasTab />\n        )}\n\n        {activeTab === \'perfil\' && (\n          <PerfilTab \n            nombre={usuario.nombre}\n            email={usuario.email}\n            whatsapp={usuario.whatsapp}\n            codigoGrupo={usuario.codigoGrupo}\n            puntosTotal={usuario.puntosTotal}\n            rankingLideres={rankingLideres}\n            onUpdateWhatsapp={handleUpdateWhatsapp}\n          />\n        )}\n      </main>\n\n      {/* Floating Leaderboard Action Button (Contextual quick tool) */}\n      <button \n        onClick={() => setShowFloatingRanking(!showFloatingRanking)}\n        className=\"fixed bottom-24 right-4 w-12 h-12 bg-[#ffe16d] text-[#121316] hover:bg-[#e9c400] rounded-full shadow-2xl flex items-center justify-center border border-[#ffe16d]/30 active:scale-90 transition-transform cursor-pointer z-40\"\n        title=\"Mostrar tabla de posiciones del grupo\"\n        aria-haspopup=\"dialog\"\n      >\n        <span className=\"material-symbols-outlined font-bold text-xl\">leaderboard</span>\n      </button>\n\n      {/* Floating Leaderboard Overview Dialogue Modal */}\n      {showFloatingRanking && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n          <div className=\"absolute inset-0 bg-black/75 backdrop-blur-sm\" onClick={() => setShowFloatingRanking(false)}></div>\n          <div className=\"relative w-full max-w-[340px] bg-[#1f1f23] border border-white/10 rounded-2xl p-5 shadow-2xl animate-in font-sans\">\n            <div className=\"flex justify-between items-center mb-4\">\n              <h4 className=\"font-display text-xl text-[#b1c6f9] tracking-wider uppercase flex items-center gap-2\">\n                <span className=\"material-symbols-outlined text-[#ffe16d]\">workspace_premium</span>\n                Tabla del Grupo\n              </h4>\n              <button onClick={() => setShowFloatingRanking(false)} className=\"text-[#8e9099] hover:text-white p-1\">\n                <span className=\"material-symbols-outlined\">close</span>\n              </button>\n            </div>\n            \n            <div className=\"space-y-2 max-h-[300px] overflow-y-auto pr-1\">\n              {rankingLideres.map(lead => {\n                const isSelf = lead.uid === \'me\';\n                return (\n                  <div \n                    key={lead.uid} \n                    className={`flex justify-between items-center p-2.5 rounded-xl ${\n                      isSelf ? \'bg-[#79ff5b]/15 border border-[#79ff5b]/30\' : \'bg-[#121316]/50\'\n                    }`}\n                  >\n                    <div className=\"flex items-center gap-2.5\">\n                      <span className=\"font-mono text-xs text-[#8e9099] w-4 text-center\">#{lead.posicion}</span>\n                      <img alt={lead.nombre} className=\"w-8 h-8 rounded-full border border-white/5\" src={lead.foto} />\n                      <span className={`text-xs font-semibold ${isSelf ? \'text-[#79ff5b]\' : \'text-slate-200\'}`}>\n                        {lead.nombre} {isSelf && \'(T\303\272)\'}\n                      </span>\n                    </div>\n                    <span className=\"font-mono text-xs text-[#ffe16d] font-bold\">{lead.puntosTotal} PTS</span>\n                  </div>\n                );\n              })}\n            </div>\n            \n            <button \n              onClick={() => {\n                setActiveTab(\'perfil\');\n                setShowFloatingRanking(false);\n              }}\n              className=\"mt-4 w-full bg-[#192f59] hover:bg-[#314671] text-[#b1c6f9] py-2 rounded-xl text-xs font-bold transition-all uppercase\"\n            >\n              Ir a Desglose Completo\n            </button>\n          </div>\n        </div>\n      )}\n\n      {/* Styled Premium Bottom Tab Bar Navigation navigation */}\n      <nav className=\"fixed bottom-0 left-0 w-full z-40 flex justify-around items-center px-4 pb-4 pt-2.5 bg-[#1b1b1f] border-t border-white/10 shadow-[0_-5px_20px_rgba(0,0,0,0.5)] rounded-t-3xl\">\n        \n        {/* Tab: Inicio */}\n        <button\n          onClick={() => setActiveTab(\'inicio\')}\n          className={`flex flex-col items-center justify-center py-2.5 px-5 rounded-full transition-all duration-200 cursor-pointer ${\n            activeTab === \'inicio\' \n              ? \'bg-[#79ff5b] text-[#022100] px-6 scale-105 font-bold shadow-lg shadow-[#79ff5b]/10\' \n              : \'text-[#c5c6d0] hover:text-[#79ff5b]\'\n          }`}\n        >\n          <span className=\"material-symbols-outlined text-[22px]\" style={{ fontVariationSettings: activeTab === \'inicio\' ? \"\'FILL\' 1\" : \"\'FILL\' 0\" }}>\n            home\n          </span>\n          <span className=\"font-sans text-xs mt-0.5 font-semibold\">Inicio</span>\n        </button>\n\n        {/* Tab: Reglas */}\n        <button\n          onClick={() => setActiveTab(\'reglas\')}\n          className={`flex flex-col items-center justify-center py-2.5 px-5 rounded-full transition-all duration-200 cursor-pointer ${\n            activeTab === \'reglas\' \n              ? \'bg-[#79ff5b] text-[#022100] px-6 scale-105 font-bold shadow-lg shadow-[#79ff5b]/10\' \n              : \'text-[#c5c6d0] hover:text-[#79ff5b]\'\n          }`}\n        >\n          <span className=\"material-symbols-outlined text-[22px]\" style={{ fontVariationSettings: activeTab === \'reglas\' ? \"\'FILL\' 1\" : \"\'FILL\' 0\" }}>\n            gavel\n          </span>\n          <span className=\"font-sans text-xs mt-0.5 font-semibold\">Reglas</span>\n        </button>\n\n        {/* Tab: Perfil */}\n        <button\n          onClick={() => setActiveTab(\'perfil\')}\n          className={`flex flex-col items-center justify-center py-2.5 px-5 rounded-full transition-all duration-200 cursor-pointer ${\n            activeTab === \'perfil\' \n              ? \'bg-[#79ff5b] text-[#022100] px-6 scale-105 font-bold shadow-lg shadow-[#79ff5b]/10\' \n              : \'text-[#c5c6d0] hover:text-[#79ff5b]\'\n          }`}\n        >\n          <span className=\"material-symbols-outlined text-[22px]\" style={{ fontVariationSettings: activeTab === \'perfil\' ? \"\'FILL\' 1\" : \"\'FILL\' 0\" }}>\n            person\n          </span>\n          <span className=\"font-sans text-xs mt-0.5 font-semibold\">Perfil</span>\n        </button>\n\n      </nav>\n    </div>\n  );\n}\n"
    }
