    replacement_chunks {
      target_content: "/* Stadium dot pattern mesh */\n.stadium-mesh {\n  background-image: radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.05) 1px, transparent 0);\n  background-size: 24px 24px;\n}\n\n/* Glass panels from screenshot design specs */\n.glass-panel {\n  background: rgba(27, 27, 31, 0.7);\n  backdrop-filter: blur(12px);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.glow-green {\n  box-shadow: 0 0 20px rgba(121, 255, 91, 0.2);\n}\n\n@keyframes float {\n  0%, 100% { transform: translateY(0); }\n  50% { transform: translateY(-10px); }\n}\n\n.animate-float {\n  animation: float 6s ease-in-out infinite;\n}"
      replacement_content: "/* Stadium dot pattern mesh in light mode with subtle dark-green points */\n.stadium-mesh {\n  background-image: radial-gradient(circle at 1px 1px, rgba(3, 66, 38, 0.05) 1px, transparent 0);\n  background-size: 20px 20px;\n}\n\n/* Elite glass-like and polished white panels conforming to the theme specs */\n.glass-panel {\n  background: rgba(255, 255, 255, 0.95);\n  backdrop-filter: blur(8px);\n  border: 1px solid rgba(0, 0, 0, 0.08);\n  box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);\n}\n\n.glow-green {\n  box-shadow: 0 4px 15px rgba(3, 66, 38, 0.15);\n}\n\n@keyframes float {\n  0%, 100% { transform: translateY(0); }\n  50% { transform: translateY(-8px); }\n}\n\n.animate-float {\n  animation: float 6s ease-in-out infinite;\n}"
    }
