    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "  return (\n    <div className=\"space-y-6\">\n      \n      {/* Simulation Console Card mimicking Cloud Function cron job */}\n      <div className=\"bg-[#1b1b1f] border border-[#ffe16d]/30 rounded-2xl p-4 shadow-lg\">\n        <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3\">\n          <div>\n            <span className=\"font-mono text-[9px] text-[#ffe16d] bg-[#ffe16d]/10 px-2.5 py-1 rounded-full border border-[#ffe16d]/20 uppercase tracking-widest font-bold\">\n              Simulador de Cloud Function\n            </span>\n            <h3 className=\"font-display text-lg text-[#e3e2e6] mt-1 tracking-wide uppercase\">\n              Actualizaci\303\263n Autom\303\241tica de Resultados (Sync API)\n            </h3>\n            <p className=\"font-sans text-xs text-[#c5c6d0]\">\n              Simula la funci\303\263n calendarizada que consulta API-Football para finalizar partidos, recalcular puntos de apuestas de inmediato.\n            </p>\n          </div>\n          <button\n            onClick={runCloudFunctionSync}\n            className=\"bg-[#ffe16d] hover:bg-[#e9c400] text-[#221b00] font-sans font-bold text-xs px-4 py-2.5 rounded-xl cursor-pointer flex items-center gap-2 transition-all active:scale-95 whitespace-nowrap shadow-md self-stretch sm:self-auto justify-center\"\n          >\n            <span className=\"material-symbols-outlined text-[16px] animate-spin\">sync</span>\n            <span>EJECUTAR CRON JOB</span>\n          </button>\n        </div>\n      </div>\n\n      {notifText && (\n        <div className=\"bg-[#0f6d00]/90 text-[#ffe16d] border border-[#79ff5b]/20 p-3.5 rounded-xl text-center font-sans text-sm font-semibold animate-bounce shadow-lg\">\n          {notifText}\n        </div>\n      )}\n\n      {/* Main Tournament Phase Indicator */}\n      <div className=\"flex items-center justify-between\">\n        <span className=\"font-mono text-xs text-[#b1c6f9] bg-[#001b44] px-3.5 py-1.5 rounded-full border border-white/5 uppercase tracking-widest font-bold\">\n          FASE DE GRUPOS\n        </span>\n        <div className=\"flex items-center gap-2\">\n          <div className=\"w-2.5 h-2.5 rounded-full bg-[#ffb4ab] animate-pulse\"></div>\n          <span className=\"font-mono text-xs text-[#ffb4ab] font-bold tracking-widest\">\n            VIVO\n          </span>\n        </div>\n      </div>\n\n      {/* Group listings of matches */}\n      {Object.entries(partidosPorFecha).map(([fecha, partidosEstrella]) => (\n        <section key={fecha} className=\"space-y-4\">\n          <div className=\"flex items-center gap-4\">\n            <h2 className=\"font-display text-4xl text-[#e3e2e6] uppercase tracking-wide leading-none\">{fecha}</h2>\n            <div className=\"h-[1px] flex-grow bg-white/10\"></div>\n          </div>\n\n          <div className=\"flex flex-col gap-4\">\n            {partidosEstrella.map(match => {\n              const apuesta = getApuestaForPartido(match.partidoId);\n              const pointsEarned = match.estado === \'finalizado\' ? (apuesta ? apuesta.puntosObtenidos : 0) : null;\n              \n              // Germany vs France locked pattern (Already played or locked because hour arrived)\n              const yaBloqueado = match.estado === \'finalizado\' || match.estado === \'en_vivo\';\n\n              return (\n                <div \n                  key={match.partidoId}\n                  className={`relative rounded-2xl border transition-all duration-300 ${\n                    yaBloqueado \n                      ? \'bg-[#1b1b1f] border-white/5 opacity-85 grayscale hover:grayscale-0\' \n                      : \'bg-[#001b44]/40 border-[#b1c6f9]/20 hover:border-[#b1c6f9]/40 shadow-xl shadow-black/20\'\n                  }`}\n                >\n                  {/* Lock Indicator / Points badge */}\n                  {match.estado === \'finalizado\' && (\n                    <div className=\"absolute top-3 right-3 z-10 flex flex-col items-end gap-1\">\n                      <span className=\"bg-[#e9c400] text-[#221b00] px-3 py-1 rounded-full font-mono text-[10px] uppercase font-bold flex items-center gap-1 shadow-lg\">\n                        <span className=\"material-symbols-outlined text-[13px] font-bold\">workspace_premium</span>\n                        +{pointsEarned} pts\n                      </span>\n                    </div>\n                  )}\n\n                  <div className=\"p-5\">\n                    {/* Header info */}\n                    <div className=\"flex justify-between items-center mb-4 border-b border-white/5 pb-2\">\n                       <span className=\"font-mono text-[10px] text-[#c5c6d0] uppercase tracking-widest\">\n                        {match.grupoTorneo} \342\200\242 {match.estadio}\n                      </span>\n                      <span className={`font-mono text-[11px] ${yaBloqueado ? \'text-[#8e9099]\' : \'text-[#79ff5b] font-bold\'}`}>\n                        {match.estado === \'en_vivo\' ? \'JUG\303\201NDOSE\' : match.estado === \'finalizado\' ? \'FINALIZADO\' : match.hora}\n                      </span>\n                    </div>\n\n                    {/* Team flags and prediction scores block */}\n                    <div className=\"flex justify-between items-center gap-1 sm:gap-4 mb-5\">\n                      \n                      {/* Local Team */}\n                      <div className=\"flex flex-col items-center gap-2 flex-1 text-center\">\n                        <div className=\"w-16 h-10 rounded overflow-hidden bg-[#0d0e11] flex items-center justify-center border border-white/10 shadow-sm relative group\">\n                          <img \n                            alt={match.equipoLocal} \n                            className=\"w-full h-full object-cover group-hover:scale-105 transition-transform\" \n                            src={match.banderaLocal} \n                            referrerPolicy=\"no-referrer\"\n                          />\n                        </div>\n                        <span className=\"font-display text-lg text-[#e3e2e6] tracking-wider truncate max-w-[100px]\">\n                          {match.equipoLocal}\n                        </span>\n                        \n                        {/* Interactive Prediction Controls */}\n                        {!yaBloqueado && (\n                          <div className=\"flex items-center gap-2 mt-1\">\n                            <button\n                              onClick={() => setLocalScore(match.partidoId, getEditingLocalScore(match.partidoId, 0) - 1)}\n                              className=\"w-8 h-8 rounded-full bg-[#343538] hover:bg-[#79ff5b] hover:text-[#022100] flex items-center justify-center cursor-pointer transition-colors active:scale-90\"\n                              aria-label=\"Disminuir goles local\"\n                            >\n                              <span className=\"material-symbols-outlined text-sm font-bold\">remove</span>\n                            </button>\n                            <span className=\"font-display text-2xl text-[#ffe16d] w-6 text-center\">\n                              {getEditingLocalScore(match.partidoId, 0)}\n                            </span>\n                            <button\n                              onClick={() => setLocalScore(match.partidoId, getEditingLocalScore(match.partidoId, 0) + 1)}\n                              className=\"w-8 h-8 rounded-full bg-[#343538] hover:bg-[#79ff5b] hover:text-[#022100] flex items-center justify-center cursor-pointer transition-colors active:scale-90\"\n                              aria-label=\"Aumentar goles local\"\n                            >\n                              <span className=\"material-symbols-outlined text-sm font-bold\">add</span>\n                            </button>\n                          </div>\n                        )}\n                      </div>\n\n                      {/* VS Divider or Real Final scores */}\n                      <div className=\"flex flex-col items-center justify-center px-2 flex-shrink-0\">\n                        {match.estado === \'finalizado\' ? (\n                          <div className=\"flex flex-col items-center\">\n                            <span className=\"font-mono text-[9px] text-[#8e9099] uppercase tracking-widest mb-1\">REAL</span>\n                            <div className=\"flex items-center gap-2\">\n                              <span className=\"font-display text-4xl text-[#79ff5b] font-bold\">\n                                {match.golesLocal}\n                              </span>\n                              <span className=\"font-mono text-sm text-white/30\">-</span>\n                              <span className=\"font-display text-4xl text-[#79ff5b] font-bold\">\n                                {match.golesVisitante}\n                              </span>\n                            </div>\n                          </div>\n                        ) : (\n                          <div className=\"w-8 h-8 rounded-full bg-white/5 flex items-center justify-center font-mono text-[10px] text-white/40\">\n                            VS\n                          </div>\n                        )}\n                      </div>\n\n                      {/* Visitant Team */}\n                      <div className=\"flex flex-col items-center gap-2 flex-1 text-center\">\n                        <div className=\"w-16 h-10 rounded overflow-hidden bg-[#0d0e11] flex items-center justify-center border border-white/10 shadow-sm relative group\">\n                          <img \n                            alt={match.equipoVisitante} \n                            className=\"w-full h-full object-cover group-hover:scale-105 transition-transform\" \n                            src={match.banderaVisitante} \n                            referrerPolicy=\"no-referrer\"\n                          />\n                        </div>\n                        <span className=\"font-display text-lg text-[#e3e2e6] tracking-wider truncate max-w-[100px]\">\n                          {match.equipoVisitante}\n                        </span>\n\n                        {!yaBloqueado && (\n                          <div className=\"flex items-center gap-2 mt-1\">\n                            <button\n                              onClick={() => setVisitanteScore(match.partidoId, getEditingVisitanteScore(match.partidoId, 0) - 1)}\n                              className=\"w-8 h-8 rounded-full bg-[#343538] hover:bg-[#79ff5b] hover:text-[#022100] flex items-center justify-center cursor-pointer transition-colors active:scale-90\"\n                              aria-label=\"Disminuir goles visitante\"\n                            >\n                              <span className=\"material-symbols-outlined text-sm font-bold\">remove</span>\n                            </button>\n                            <span className=\"font-display text-2xl text-[#ffe16d] w-6 text-center\">\n                              {getEditingVisitanteScore(match.partidoId, 0)}\n                            </span>\n                            <button\n                              onClick={() => setVisitanteScore(match.partidoId, getEditingVisitanteScore(match.partidoId, 0) + 1)}\n                              className=\"w-8 h-8 rounded-full bg-[#343538] hover:bg-[#79ff5b] hover:text-[#022100] flex items-center justify-center cursor-pointer transition-colors active:scale-90\"\n                              aria-label=\"Aumentar goles visitante\"\n                            >\n                              <span className=\"material-symbols-outlined text-sm font-bold\">add</span>\n                            </button>\n                          </div>\n                        )}\n                      </div>\n\n                    </div>\n\n                    {/* Footer Lock state/Prediction notification message */}\n                    <div className=\"mt-4 pt-3 border-t border-white/5 flex items-center justify-between text-xs text-[#c5c6d0]\">\n                      {yaBloqueado ? (\n                        <div className=\"w-full flex items-center gap-2 text-[#8e9099] font-sans justify-center bg-white/5 py-2.5 rounded-xl\">\n                          <span className=\"material-symbols-outlined text-[16px] text-[#ffe16d]\">lock</span>\n                          <span>\n                            {apuesta \n                              ? `Tu Predicci\303\263n: ${apuesta.golesLocalApuesta} - ${apuesta.golesVisitanteApuesta}` \n                              : \'No ingresaste predicci\303\263n para este encuentro\'}\n                          </span>\n                        </div>\n                      ) : (\n                        <button\n                          onClick={() => submitApuesta(match.partidoId)}\n                          className=\"w-full bg-[#79ff5b] hover:bg-[#2ae500] text-[#022100] font-sans font-bold py-3 rounded-xl flex items-center justify-center gap-2 active:scale-[0.98] transition-all cursor-pointer shadow-lg shadow-[#79ff5b]/10\"\n                        >\n                          <span className=\"material-symbols-outlined text-[18px]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                            save\n                          </span>\n                          <span>GUARDAR APUESTA</span>\n                        </button>\n                      )}\n                    </div>\n\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </section>\n      ))}\n\n    </div>\n  );"
      replacement_content: "  return (\n    <div className=\"space-y-6\">\n      \n      {/* Simulation Console Card mimicking Cloud Function cron job */}\n      <div className=\"bg-[#034226] border-2 border-[#e1b12c] rounded-2xl p-5 shadow-xl text-white\">\n        <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n          <div>\n            <span className=\"font-mono text-[9px] text-[#034226] bg-[#e1b12c] px-2.5 py-1 rounded-full uppercase tracking-widest font-extrabold shadow-sm\">\n              Simulador de Cloud Function\n            </span>\n            <h3 className=\"font-display text-xl text-white mt-2 tracking-wide uppercase\">\n              Actualizaci\303\263n Autom\303\241tica de Resultados (Sync API)\n            </h3>\n            <p className=\"font-sans text-xs text-slate-200 mt-1 leading-relaxed\">\n              Simula la funci\303\263n calendarizada que consulta API-Football para finalizar partidos, recalcular puntos de apuestas de inmediato.\n            </p>\n          </div>\n          <button\n            onClick={runCloudFunctionSync}\n            className=\"bg-[#e1b12c] hover:bg-[#cda024] text-[#034226] font-sans font-bold text-xs px-5 py-2.5 rounded-xl cursor-pointer flex items-center gap-2 transition-all active:scale-95 whitespace-nowrap shadow-md self-stretch sm:self-auto justify-center\"\n          >\n            <span className=\"material-symbols-outlined text-[16px] font-bold\">sync</span>\n            <span>EJECUTAR CRON JOB</span>\n          </button>\n        </div>\n      </div>\n\n      {notifText && (\n        <div className=\"bg-[#034226] text-white border-2 border-[#e1b12c] p-3.5 rounded-xl text-center font-sans text-xs font-bold animate-pulse shadow-lg\">\n          {notifText}\n        </div>\n      )}\n\n      {/* Main Tournament Phase Indicator */}\n      <div className=\"flex items-center justify-between\">\n        <span className=\"font-sans text-xs text-[#034226] bg-[#034226]/10 px-3.5 py-1.5 rounded-full border border-[#034226]/20 uppercase tracking-widest font-bold\">\n          FASE DE GRUPOS\n        </span>\n        <div className=\"flex items-center gap-2\">\n          <div className=\"w-2.5 h-2.5 rounded-full bg-red-500 animate-pulse\"></div>\n          <span className=\"font-sans text-xs text-red-600 font-bold tracking-widest\">\n            VIVO\n          </span>\n        </div>\n      </div>\n\n      {/* Group listings of matches */}\n      {Object.entries(partidosPorFecha).map(([fecha, partidosEstrella]) => (\n        <section key={fecha} className=\"space-y-4\">\n          <div className=\"flex items-center gap-4\">\n            <h2 className=\"font-display text-4xl text-slate-800 uppercase tracking-wide leading-none\">{fecha}</h2>\n            <div className=\"h-[1px] flex-grow bg-slate-200\"></div>\n          </div>\n\n          <div className=\"flex flex-col gap-4\">\n            {partidosEstrella.map(match => {\n              const apuesta = getApuestaForPartido(match.partidoId);\n              const pointsEarned = match.estado === \'finalizado\' ? (apuesta ? apuesta.puntosObtenidos : 0) : null;\n              \n              const yaBloqueado = match.estado === \'finalizado\' || match.estado === \'en_vivo\';\n\n              return (\n                <div \n                  key={match.partidoId}\n                  className={`relative rounded-2xl border transition-all duration-300 overflow-hidden ${\n                    yaBloqueado \n                      ? \'bg-slate-50 border-slate-200 opacity-90 shadow-sm\' \n                      : \'bg-white border-2 border-[#034226]/15 hover:border-[#034226]/45 shadow-[0_4px_20px_rgba(0,0,0,0.02)]\'\n                  }`}\n                >\n                  {/* Lock Indicator / Points badge */}\n                  {match.estado === \'finalizado\' && (\n                    <div className=\"absolute top-3 right-3 z-10 flex flex-col items-end gap-1\">\n                      <span className=\"bg-[#e1b12c] text-[#034226] px-3 py-1 rounded-full font-sans text-xs uppercase font-extrabold flex items-center gap-1 shadow-md border border-[#e1b12c]/40\">\n                        <span className=\"material-symbols-outlined text-[14px] font-bold\">workspace_premium</span>\n                        +{pointsEarned} pts\n                      </span>\n                    </div>\n                  )}\n\n                  <div className=\"p-5\">\n                    {/* Header info */}\n                    <div className=\"flex justify-between items-center mb-4 border-b border-slate-100 pb-2\">\n                      <span className=\"font-sans text-[10px] text-slate-400 font-bold uppercase tracking-wider\">\n                        {match.grupoTorneo} \342\200\242 {match.estadio}\n                      </span>\n                      <span className={`font-mono text-xs font-bold uppercase ${yaBloqueado ? \'text-slate-400\' : \'text-[#034226]\'}`}>\n                        {match.estado === \'en_vivo\' ? \'JUG\303\201NDOSE\' : match.estado === \'finalizado\' ? \'FINALIZADO\' : match.hora}\n                      </span>\n                    </div>\n\n                    {/* Team flags and prediction scores block */}\n                    <div className=\"grid grid-cols-3 items-center gap-1 sm:gap-4 mb-3\">\n                      \n                      {/* Local Team */}\n                      <div className=\"flex flex-col items-center gap-2 text-center\">\n                        <div className=\"w-16 h-10 rounded overflow-hidden bg-slate-100 flex items-center justify-center border border-slate-200 shadow-sm relative group\">\n                          <img \n                            alt={match.equipoLocal} \n                            className=\"w-full h-full object-cover group-hover:scale-105 transition-transform\" \n                            src={match.banderaLocal} \n                            referrerPolicy=\"no-referrer\"\n                          />\n                        </div>\n                        <span className=\"font-display text-lg text-slate-700 tracking-wider truncate max-w-[124px]\">\n                          {match.equipoLocal}\n                        </span>\n                        \n                        {/* Interactive Prediction Controls */}\n                        {!yaBloqueado && (\n                          <div className=\"flex items-center gap-2 mt-1 bg-slate-50 border border-slate-200/80 rounded-full px-2 py-1\">\n                            <button\n                              onClick={() => setLocalScore(match.partidoId, getEditingLocalScore(match.partidoId, 0) - 1)}\n                              className=\"w-8 h-8 rounded-full bg-white hover:bg-[#034226] hover:text-white text-slate-600 flex items-center justify-center cursor-pointer transition-colors active:scale-95 border border-slate-200 shadow-sm\"\n                              aria-label=\"Disminuir goles local\"\n                            >\n                              <span className=\"material-symbols-outlined text-xs font-bold\">remove</span>\n                            </button>\n                            <span className=\"font-display text-2xl text-[#034226] w-6 text-center font-bold\">\n                              {getEditingLocalScore(match.partidoId, 0)}\n                            </span>\n                            <button\n                              onClick={() => setLocalScore(match.partidoId, getEditingLocalScore(match.partidoId, 0) + 1)}\n                              className=\"w-8 h-8 rounded-full bg-white hover:bg-[#034226] hover:text-white text-slate-600 flex items-center justify-center cursor-pointer transition-colors active:scale-95 border border-slate-200 shadow-sm\"\n                              aria-label=\"Aumentar goles local\"\n                            >\n                              <span className=\"material-symbols-outlined text-xs font-bold\">add</span>\n                            </button>\n                          </div>\n                        )}\n                      </div>\n\n                      {/* VS Divider or Real Final scores */}\n                      <div className=\"flex flex-col items-center justify-center px-1 flex-shrink-0\">\n                        {match.estado === \'finalizado\' ? (\n                          <div className=\"flex flex-col items-center bg-slate-100 px-3 py-1.5 rounded-xl border border-slate-200/50\">\n                            <span className=\"font-sans text-[8px] text-slate-400 font-bold uppercase tracking-wider mb-0.5\">Real</span>\n                            <div className=\"flex items-center gap-2\">\n                              <span className=\"font-display text-3xl text-[#034226] font-black\">\n                                {match.golesLocal}\n                              </span>\n                              <span className=\"font-mono text-xs text-slate-400\">-</span>\n                              <span className=\"font-display text-3xl text-[#034226] font-black\">\n                                {match.golesVisitante}\n                              </span>\n                            </div>\n                          </div>\n                        ) : (\n                          <div className=\"w-9 h-9 rounded-full bg-slate-100 flex items-center justify-center font-bold text-[10px] text-slate-400 border border-slate-200 shadow-inner\">\n                            VS\n                          </div>\n                        )}\n                      </div>\n\n                      {/* Visitant Team */}\n                      <div className=\"flex flex-col items-center gap-2 text-center\">\n                        <div className=\"w-16 h-10 rounded overflow-hidden bg-slate-100 flex items-center justify-center border border-slate-200 shadow-sm relative group\">\n                          <img \n                            alt={match.equipoVisitante} \n                            className=\"w-full h-full object-cover group-hover:scale-105 transition-transform\" \n                            src={match.banderaVisitante} \n                            referrerPolicy=\"no-referrer\"\n                          />\n                        </div>\n                        <span className=\"font-display text-lg text-slate-700 tracking-wider truncate max-w-[124px]\">\n                          {match.equipoVisitante}\n                        </span>\n\n                        {!yaBloqueado && (\n                          <div className=\"flex items-center gap-2 mt-1 bg-slate-50 border border-slate-200/80 rounded-full px-2 py-1\">\n                            <button\n                              onClick={() => setVisitanteScore(match.partidoId, getEditingVisitanteScore(match.partidoId, 0) - 1)}\n                              className=\"w-8 h-8 rounded-full bg-white hover:bg-[#034226] hover:text-white text-slate-600 flex items-center justify-center cursor-pointer transition-colors active:scale-95 border border-slate-200 shadow-sm\"\n                              aria-label=\"Disminuir goles visitante\"\n                            >\n                              <span className=\"material-symbols-outlined text-xs font-bold\">remove</span>\n                            </button>\n                            <span className=\"font-display text-2xl text-[#034226] w-6 text-center font-bold\">\n                              {getEditingVisitanteScore(match.partidoId, 0)}\n                            </span>\n                            <button\n                              onClick={() => setVisitanteScore(match.partidoId, getEditingVisitanteScore(match.partidoId, 0) + 1)}\n                              className=\"w-8 h-8 rounded-full bg-white hover:bg-[#034226] hover:text-white text-slate-600 flex items-center justify-center cursor-pointer transition-colors active:scale-95 border border-slate-200 shadow-sm\"\n                              aria-label=\"Aumentar goles visitante\"\n                            >\n                              <span className=\"material-symbols-outlined text-xs font-bold\">add</span>\n                            </button>\n                          </div>\n                        )}\n                      </div>\n\n                    </div>\n\n                    {/* Footer Lock state/Prediction notification message */}\n                    <div className=\"mt-4 pt-3 border-t border-slate-150 flex items-center justify-between text-xs text-slate-600\">\n                      {yaBloqueado ? (\n                        <div className=\"w-full flex items-center gap-2 text-slate-500 font-sans justify-center bg-slate-100 py-2.5 rounded-xl border border-slate-200/40\">\n                          <span className=\"material-symbols-outlined text-[16px] text-[#e1b12c] font-bold\">lock</span>\n                          <span className=\"font-medium text-xs\">\n                            {apuesta \n                              ? `Tu Pron\303\263stico: ${apuesta.golesLocalApuesta} - ${apuesta.golesVisitanteApuesta}` \n                              : \'No ingresaste predicci\303\263n para este encuentro\'}\n                          </span>\n                        </div>\n                      ) : (\n                        <button\n                          onClick={() => submitApuesta(match.partidoId)}\n                          className=\"w-full bg-[#034226] hover:bg-[#02331d] text-white font-sans font-bold py-3.5 rounded-xl flex items-center justify-center gap-2 active:scale-[0.98] transition-all cursor-pointer shadow-md\"\n                        >\n                          <span className=\"material-symbols-outlined text-[18px]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                            save\n                          </span>\n                          <span>GUARDAR APUESTA</span>\n                        </button>\n                      )}\n                    </div>\n\n                  </div>\n                </div>\n              );\n            })}\n          </div>\n        </section>\n      ))}\n\n    </div>\n  );"
    }
