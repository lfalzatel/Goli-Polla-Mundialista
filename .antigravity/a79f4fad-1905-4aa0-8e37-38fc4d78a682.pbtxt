      replacement_content: "  return (\n    <div className=\"relative min-h-screen w-full flex items-center justify-center overflow-y-auto px-4 py-8 z-10\">\n      {/* Background Layer with Stadium mesh & light gradient overlay */}\n      <div className=\"fixed inset-0 -z-10 bg-gradient-to-b from-slate-200 via-slate-100 to-slate-100\"></div>\n      <div className=\"fixed inset-0 -z-10 stadium-mesh opacity-50\"></div>\n\n      {/* Main Entry Panel */}\n      <div className={`relative w-full max-w-[400px] flex flex-col items-center transition-all duration-300 ${showWhatsAppModal ? \'blur-md scale-95 opacity-50\' : \'opacity-100\'}`}>\n        \n        {/* Brand logo & title */}\n        <div className=\"mb-8 text-center animate-float\">\n          <div className=\"relative inline-block mb-4\">\n            <div className=\"absolute inset-0 bg-[#034226]/10 blur-2xl rounded-full\"></div>\n            <div className=\"relative w-28 h-28 flex items-center justify-center bg-[#034226] rounded-full border-4 border-[#e1b12c] shadow-[0_10px_25px_rgba(3,66,38,0.25)]\">\n              <span className=\"material-symbols-outlined text-[56px] text-[#e1b12c]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                sports_soccer\n              </span>\n            </div>\n          </div>\n          <h1 className=\"font-display text-5xl text-[#034226] tracking-wider mb-1 leading-none uppercase\">\n            POLLA MUNDIALISTA <span className=\"text-[#e1b12c]\">FOE</span>\n          </h1>\n          <p className=\"font-mono text-[10px] text-slate-500 tracking-widest uppercase font-bold\">\n            Elite Prediction League\n          </p>\n        </div>\n\n        {/* Login interactive card */}\n        <div className=\"w-full bg-white rounded-2xl p-6 flex flex-col gap-5 border border-slate-200 shadow-[0_8px_30px_rgb(0,0,0,0.06)]\">\n          <form onSubmit={handleGoogleLoginAttempt} className=\"space-y-4\">\n            <div className=\"flex flex-col gap-2\">\n              <label id=\"acceso-label-id\" className=\"font-sans text-xs font-bold text-slate-500 px-1 uppercase tracking-wider block\">\n                C\303\263digo de Acceso (Grupo)\n              </label>\n              \n              <div className=\"relative group\">\n                <span className=\"material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-[#034226] transition-colors\">\n                  group\n                </span>\n                <input\n                  id=\"group-input-id\"\n                  className=\"w-full bg-slate-50 border-2 border-slate-200 focus:border-[#034226] focus:ring-1 focus:ring-[#034226] rounded-xl py-3.5 pl-11 pr-4 font-mono text-sm text-slate-800 placeholder-slate-400 transition-all outline-none\"\n                  placeholder=\"EJ: CHAMPIONS-2024\"\n                  type=\"text\"\n                  value={codigoGrupo}\n                  onChange={(e) => setCodigoGrupo(e.target.value)}\n                />\n              </div>\n            </div>\n\n            {errorText && !showWhatsAppModal && (\n              <p className=\"text-red-600 text-xs font-semibold px-2\">\n                {errorText}\n              </p>\n            )}\n\n            {/* Simulated Authenticator credentials default preview */}\n            <div className=\"text-center text-[11px] text-slate-500 bg-slate-100 rounded-lg py-2 px-3 flex justify-between border border-slate-200/60\">\n              <span className=\"font-medium\">Google Account:</span>\n              <span className=\"text-[#034226] font-mono font-bold\">{googleEmail}</span>\n            </div>\n\n            {/* Submit button mimicking google auth */}\n            <button\n              id=\"submit-google-login-btn\"\n              type=\"submit\"\n              className=\"w-full bg-[#034226] hover:bg-[#02331d] text-white font-sans text-sm font-bold py-3.5 rounded-xl flex items-center justify-center gap-3 transition-all active:scale-[0.98] cursor-pointer shadow-md duration-300\"\n            >\n              <svg className=\"w-5 h-5 flex-shrink-0\" viewBox=\"0 0 24 24\">\n                <path d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" fill=\"#4285F4\"></path>\n                <path d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" fill=\"#34A853\"></path>\n                <path d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z\" fill=\"#FBBC05\"></path>\n                <path d=\"M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 12-4.53z\" fill=\"#EA4335\"></path>\n              </svg>\n              <span>Acceder con Google</span>\n            </button>\n          </form>\n\n          <p className=\"text-center font-sans text-xs text-slate-400 mt-1\">\n            \302\277No tienes grupo?{\' \'}\n            <a href=\"https://wa.me/573000000000\" target=\"_blank\" rel=\"noreferrer\" className=\"text-[#034226] hover:text-[#e1b12c] hover:underline font-bold transition-colors\">\n              Contactar Administrador\n            </a>\n          </p>\n        </div>\n\n        {/* Decorative stats */}\n        <div className=\"mt-8 flex gap-8 opacity-90 scale-95\">\n          <div className=\"flex flex-col items-center\">\n            <span className=\"font-display text-4xl text-[#034226]\">12k+</span>\n            <span className=\"font-mono text-[9px] uppercase tracking-wider text-slate-500 font-bold\">Jugadores</span>\n          </div>\n          <div className=\"w-[1px] bg-slate-300 h-8 self-center\"></div>\n          <div className=\"flex flex-col items-center\">\n            <span className=\"font-display text-4xl text-[#e1b12c]\">\360\237\217\206</span>\n            <span className=\"font-mono text-[9px] uppercase tracking-wider text-slate-500 font-bold\">Grandes Premios</span>\n          </div>\n        </div>\n      </div>\n\n      {/* WhatsApp Modal Dialog (Renders as light themed persistent overlay) */}\n      {showWhatsAppModal && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n          <div className=\"absolute inset-0 bg-slate-900/60 backdrop-blur-sm\"></div>\n          <div className=\"relative w-full max-w-[360px] bg-white rounded-2xl p-6 flex flex-col gap-5 shadow-[0_15px_50px_rgba(0,0,0,0.15)] border border-slate-200 animate-in fade-in zoom-in duration-300\">\n            \n            <div className=\"flex justify-between items-start\">\n              <div className=\"w-12 h-12 rounded-full bg-[#034226]/10 flex items-center justify-center text-[#034226]\">\n                <span className=\"material-symbols-outlined\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                  chat\n                </span>\n              </div>\n              <button \n                onClick={() => setShowWhatsAppModal(false)}\n                className=\"text-slate-400 hover:text-slate-700 transition-colors p-1\"\n                aria-label=\"Cerrar modal\"\n              >\n                <span className=\"material-symbols-outlined\">close</span>\n              </button>\n            </div>\n\n            <div className=\"space-y-1\">\n              <h2 className=\"font-display text-3xl text-[#034226] leading-none uppercase\">PASO FINAL</h2>\n              <p className=\"font-sans text-xs text-slate-500 leading-snug\">\n                Registra tu n\303\272mero celular para recibir tus notificaciones personalizadas e invitaciones.\n              </p>\n            </div>\n\n            <form onSubmit={handleWhatsAppSubmit} className=\"space-y-4\">\n              <div className=\"flex flex-col gap-2\">\n                <div className=\"relative\">\n                  <span className=\"absolute left-3 top-1/2 -translate-y-1/2 font-sans text-xs font-bold text-slate-400 border-r border-slate-200 pr-2\">\n                    +57\n                  </span>\n                  <input\n                    required\n                    className=\"w-full bg-slate-50 border-2 border-slate-200 focus:border-[#034226] focus:ring-1 focus:ring-[#034226] rounded-xl py-3.5 pl-15 pr-4 font-mono text-sm text-slate-800 placeholder-slate-400 outline-none transition-all\"\n                    placeholder=\"300 000 0000\"\n                    type=\"tel\"\n                    value={whatsappNumber}\n                    onChange={(e) => setWhatsappNumber(e.target.value)}\n                  />\n                </div>\n              </div>\n\n              {errorText && (\n                <p className=\"text-red-600 text-xs font-semibold px-1\">\n                  {errorText}\n                </p>\n              )}\n\n              <button\n                type=\"submit\"\n                className=\"w-full bg-[#034226] hover:bg-[#02331d] text-white font-sans font-bold py-3.5 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-[0.98] shadow-md cursor-pointer text-sm uppercase\"\n              >\n                <span>COMENZAR</span>\n                <span className=\"material-symbols-outlined text-[16px] font-bold\">arrow_forward</span>\n              </button>\n            </form>\n\n            <p className=\"text-[10px] text-center text-slate-400 font-sans uppercase tracking-tight leading-tight mt-1\">\n              Tus datos se manejan con seguridad de nivel deportivo.\n            </p>\n          </div>\n        </div>\n      )}\n    </div>\n  );"
