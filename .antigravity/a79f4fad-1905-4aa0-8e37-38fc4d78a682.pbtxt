  file_change {
    absolute_path_uri: "file:///src/components/PerfilTab.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \'react\';\nimport { RankedUser } from \'../types\';\nimport { HISTORIAL_DESGLOSE_MOCK } from \'../data\';\n\ninterface PerfilTabProps {\n  nombre: string;\n  email: string;\n  whatsapp: string;\n  codigoGrupo: string;\n  puntosTotal: number;\n  rankingLideres: RankedUser[];\n  onUpdateWhatsapp: (newPhone: string) => void;\n}\n\nexport default function PerfilTab({\n  nombre,\n  email,\n  whatsapp,\n  codigoGrupo,\n  puntosTotal,\n  rankingLideres,\n  onUpdateWhatsapp\n}: PerfilTabProps) {\n  const [phoneNumber, setPhoneNumber] = useState(whatsapp);\n  const [isEditing, setIsEditing] = useState(false);\n  const [showAllLeaderboard, setShowAllLeaderboard] = useState(false);\n  const [saveSuccess, setSaveSuccess] = useState(false);\n\n  // Sorting leaderboard users so they match positions perfectly\n  const sortedRanking = [...rankingLideres].sort((a, b) => {\n    // If we have \"me\", we can ensure position is set correctly\n    return a.posicion - b.posicion;\n  });\n\n  // Decide which users to show\n  const visibleRanking = showAllLeaderboard ? sortedRanking : sortedRanking.slice(0, 4);\n\n  const handleSavePhone = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!phoneNumber.trim()) return;\n    onUpdateWhatsapp(phoneNumber);\n    setIsEditing(false);\n    setSaveSuccess(true);\n    setTimeout(() => setSaveSuccess(false), 3000);\n  };\n\n  return (\n    <div className=\"space-y-6\">\n      \n      {/* Profile Hero Enclosure */}\n      <section className=\"relative overflow-hidden bg-[#1f1f23] border border-white/5 rounded-2xl p-6 shadow-xl stadium-mesh\">\n        \n        {/* Glow vector back */}\n        <div className=\"absolute top-0 right-0 w-32 h-32 bg-[#2ff801]/10 blur-3xl rounded-full\"></div>\n\n        <div className=\"relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6\">\n          \n          {/* Avatar and metadata info */}\n          <div className=\"flex items-center gap-4\">\n            <div className=\"relative shrink-0\">\n              <div className=\"w-20 h-20 rounded-full border-4 border-[#79ff5b] p-1 shadow-lg bg-[#121316]\">\n                <img \n                  alt={nombre} \n                  className=\"w-full h-full rounded-full object-cover\" \n                  src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuB51HhLfnZaDiGtKYp7MwISidlkzLIvjuKRkqP-Z4Ht2dfgJK3G8Ve2q4QdXolTh7pung4KkLRXjVW-wEb_4UESxWciOP6HrVq2_JhM1XYhDssQTl7p5-ey-rgv2tfQCzfManWqd5WgZ8rShV-0IJFalxgyqdM5DuGNi-aMWPgI2fDBTcvn1bDgPNRX6YlC9MMlGEC_qv3OozOdRzTAWf5n3njxyzJz_10pMEEW1tGZ9t6OAaoy2zhSTVl1dQ10KnYavNUUhU2_0RU\"\n                  referrerPolicy=\"no-referrer\"\n                />\n              </div>\n              <div className=\"absolute -bottom-1 -right-1 bg-[#79ff5b] text-[#022100] px-2 py-0.5 rounded-full font-mono font-bold text-[9px] uppercase shadow-md\">\n                PRO\n              </div>\n            </div>\n            \n            <div className=\"space-y-1\">\n              <h2 className=\"font-display text-3xl text-[#e3e2e6] tracking-wide leading-none\">{nombre}</h2>\n              <div className=\"flex items-center gap-1.5 text-[#c5c6d0]\">\n                <span className=\"material-symbols-outlined text-[18px] text-[#79ff5b]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                  verified\n                </span>\n                <span className=\"font-mono text-[11px] uppercase tracking-wider\">\n                  Ranking Global: #14\n                </span>\n              </div>\n              <p className=\"font-mono text-[10px] text-[#8e9099] uppercase\">Grupo Activo: {codigoGrupo}</p>\n            </div>\n          </div>\n\n          {/* Points Enclosure counter panel */}\n          <div className=\"flex flex-col items-center justify-center bg-[#001b44]/40 px-5 py-4 rounded-2xl border border-[#b1c6f9]/20 min-w-[140px] shadow-inner text-center\">\n            <span className=\"font-mono text-[10px] text-[#b1c6f9] uppercase tracking-widest font-bold\">Total Puntos</span>\n            <span className=\"font-display text-5xl text-[#79ff5b] leading-tight font-bold\">{puntosTotal}</span>\n          </div>\n\n        </div>\n\n        {/* Editable Contacts fields */}\n        <div className=\"relative z-10 mt-6 grid grid-cols-1 md:grid-cols-2 gap-4 pt-5 border-t border-white/5\">\n          <form onSubmit={handleSavePhone} className=\"space-y-2\">\n            <label className=\"font-mono text-xs text-[#c5c6d0] block ml-1 uppercase\">\n              WhatsApp de Contacto\n            </label>\n            <div className=\"relative flex items-center\">\n              <span className=\"material-symbols-outlined absolute left-4 text-[#79ff5b]\">\n                call\n              </span>\n              \n              <input\n                disabled={!isEditing}\n                className={`w-full bg-[#292a2d] border rounded-full py-3 pl-12 pr-12 text-[#e3e2e6] font-sans text-sm focus:ring-2 focus:ring-[#79ff5b] focus:border-transparent transition-all outline-none ${\n                  isEditing ? \'border-[#79ff5b]/50 cursor-text\' : \'border-white/5 cursor-not-allowed\'\n                }`}\n                type=\"text\"\n                value={phoneNumber}\n                onChange={(e) => setPhoneNumber(e.target.value)}\n              />\n\n              {!isEditing ? (\n                <button\n                  type=\"button\"\n                  onClick={() => setIsEditing(true)}\n                  className=\"absolute right-3 text-[#79ff5b] hover:bg-[#79ff5b]/10 p-2 rounded-full transition-all cursor-pointer\"\n                  title=\"Editar WhatsApp\"\n                  aria-label=\"Editar\"\n                >\n                  <span className=\"material-symbols-outlined text-[18px]\">edit</span>\n                </button>\n              ) : (\n                <button\n                  type=\"submit\"\n                  className=\"absolute right-3 text-[#ffe16d] hover:bg-[#ffe16d]/10 p-1.5 rounded-full transition-all cursor-pointer\"\n                  title=\"Guardar WhatsApp\"\n                  aria-label=\"Guardar\"\n                >\n                  <span className=\"material-symbols-outlined text-[20px]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                    check\n                  </span>\n                </button>\n              )}\n            </div>\n\n            {saveSuccess && (\n              <p className=\"text-[#79ff5b] text-xs font-semibold px-2\">\n                \302\241N\303\272mero de contacto actualizado en local storage!\n              </p>\n            )}\n          </form>\n        </div>\n      </section>\n\n      {/* Leaderboard standing block */}\n      <section className=\"space-y-4\">\n        <div className=\"flex items-center justify-between px-1\">\n          <h3 className=\"font-display text-2xl text-[#e3e2e6] flex items-center gap-2 uppercase tracking-wide\">\n            <span className=\"material-symbols-outlined text-[#ffe16d]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n              leaderboard\n            </span>\n            Ranking del Grupo\n          </h3>\n          <button\n            onClick={() => setShowAllLeaderboard(!showAllLeaderboard)}\n            className=\"font-mono text-xs text-[#b1c6f9] flex items-center gap-1 hover:underline cursor-pointer tracking-wider font-bold\"\n          >\n            {showAllLeaderboard ? \'Ver Menos\' : \'Ver Todos\'} \n            <span className=\"material-symbols-outlined text-[16px]\">{showAllLeaderboard ? \'expand_less\' : \'chevron_right\'}</span>\n          </button>\n        </div>\n\n        <div className=\"bg-[#1f1f23] border border-white/5 rounded-2xl overflow-hidden divide-y divide-white/5 shadow-xl\">\n          {visibleRanking.map(user => {\n            const isSelf = user.uid === \'me\';\n            \n            // Format first place crown etc.\n            return (\n              <div\n                key={user.uid}\n                className={`flex items-center justify-between p-4 transition-all ${\n                  isSelf \n                    ? \'bg-[#79ff5b]/10 border-l-4 border-[#79ff5b] relative\' \n                    : \'hover:bg-white/5\'\n                }`}\n              >\n                <div className=\"flex items-center gap-4\">\n                  {/* Position indicator */}\n                  {user.posicion === 1 ? (\n                    <div className=\"w-8 h-8 flex items-center justify-center rounded-full bg-gradient-to-br from-[#ffe16d] to-[#e9c400] text-[#221b00] font-display text-lg font-bold\">\n                      1\n                    </div>\n                  ) : user.posicion === 2 ? (\n                    <div className=\"w-8 h-8 flex items-center justify-center rounded-full bg-slate-400 text-[#121316] font-display text-lg font-bold\">\n                      2\n                    </div>\n                  ) : user.posicion === 3 ? (\n                    <div className=\"w-8 h-8 flex items-center justify-center rounded-full bg-amber-700/60 text-white font-display text-lg font-bold\">\n                      3\n                    </div>\n                  ) : (\n                    <span className=\"font-display text-lg text-[#8e9099] w-8 text-center\">{user.posicion}</span>\n                  )}\n\n                  {/* Avatar thumbnail */}\n                  <div className={`w-10 h-10 rounded-full overflow-hidden shrink-0 border ${isSelf ? \'border-[#79ff5b]\' : \'border-white/10\'}`}>\n                    <img \n                      alt={user.nombre} \n                      className=\"w-full h-full object-cover\" \n                      src={user.foto} \n                      referrerPolicy=\"no-referrer\"\n                    />\n                  </div>\n\n                  <div>\n                    <span className={`font-sans text-sm font-bold block ${isSelf ? \'text-[#79ff5b]\' : \'text-[#e3e2e6]\'}`}>\n                      {user.nombre} {isSelf && \'(T\303\272)\'}\n                    </span>\n                    <span className=\"font-mono text-[10px] text-[#79ff5b] font-bold\">\n                      {user.isMe ? \'Subiendo 2 puestos\' : user.tendencia === \'subiendo\' ? \'\342\226\262 Subiendo\' : user.tendencia === \'bajando\' ? \'\342\226\274 Bajando\' : \' Estable\'}\n                    </span>\n                  </div>\n                </div>\n\n                <div className=\"text-right\">\n                  <span className=\"font-display text-2xl text-[#ffe16d] font-bold block\">{user.puntosTotal}</span>\n                  <span className=\"block font-mono text-[8px] text-[#8e9099] tracking-widest\">PTS</span>\n                </div>\n              </div>\n            );\n          })}\n        </div>\n      </section>\n\n      {/* Bets Breakdowns historic details */}\n      <section className=\"space-y-4 pb-10\">\n        <h3 className=\"font-display text-2xl text-[#e3e2e6] flex items-center gap-2 uppercase tracking-wide px-1\">\n          <span className=\"material-symbols-outlined text-[#79ff5b]\">history</span>\n          Desglose de Apuestas\n        </h3>\n\n        <div className=\"space-y-4\">\n          {HISTORIAL_DESGLOSE_MOCK.map((item, idx) => {\n            return (\n              <div \n                key={idx}\n                className={`bg-[#1f1f23] rounded-2xl p-4 flex flex-col gap-4 border-l-4 border-solid ${item.colorLeft} shadow-lg`}\n              >\n                \n                {/* Header row */}\n                <div className=\"flex justify-between items-center border-b border-white/5 pb-2\">\n                  <span className=\"font-mono text-[10px] text-[#c5c6d0] tracking-widest\">{item.fase}</span>\n                  <div className={`flex items-center gap-1 px-2.5 py-0.5 rounded font-mono text-[9px] font-bold tracking-wider ${item.badgeColor}`}>\n                    <span className=\"material-symbols-outlined text-[13px] font-bold\">\n                      {item.tipo === \'SIN ACIERTOS\' ? \'cancel\' : item.tipo === \'ACIERT\303\223 GANADOR\' ? \'check_circle\' : \'star\'}\n                    </span>\n                    <span>{item.tipo}</span>\n                  </div>\n                </div>\n\n                {/* Score panel rows */}\n                <div className=\"grid grid-cols-3 items-center text-center\">\n                  \n                  {/* Local Flag info */}\n                  <div className=\"flex flex-col items-center gap-1\">\n                    <div className=\"w-12 h-8 rounded overflow-hidden bg-[#0d0e11] flex items-center justify-center border border-white/5\">\n                      <img \n                        alt={item.local} \n                        className=\"w-full h-full object-cover\" \n                        src={item.banderaLoc} \n                        referrerPolicy=\"no-referrer\"\n                      />\n                    </div>\n                    <span className=\"font-mono text-xs font-semibold\">{item.local}</span>\n                  </div>\n\n                  {/* Bet vs Real scores detail */}\n                  <div className=\"flex flex-col items-center justify-center\">\n                    <div className=\"flex items-center gap-2\">\n                      <div className=\"flex flex-col items-center\">\n                        <span className=\"font-mono text-[8px] text-[#8e9099] uppercase\">Tu Polla</span>\n                        <span className=\"font-display text-xl text-[#ffe16d]\">{item.golesLocApuesta} - {item.golesVisApuesta}</span>\n                      </div>\n                      <div className=\"h-6 w-[1px] bg-white/10 mx-1\"></div>\n                      <div className=\"flex flex-col items-center\">\n                        <span className=\"font-mono text-[8px] text-[#8e9099] uppercase\">Real</span>\n                        <span className=\"font-display text-xl text-[#79ff5b] font-bold\">{item.golesLocReal} - {item.golesVisReal}</span>\n                      </div>\n                    </div>\n                  </div>\n\n                  {/* Visiter Flag info */}\n                  <div className=\"flex flex-col items-center gap-1\">\n                    <div className=\"w-12 h-8 rounded overflow-hidden bg-[#0d0e11] flex items-center justify-center border border-white/5\">\n                      <img \n                        alt={item.visitante} \n                        className=\"w-full h-full object-cover\" \n                        src={item.banderaVis} \n                        referrerPolicy=\"no-referrer\"\n                      />\n                    </div>\n                    <span className=\"font-mono text-xs font-semibold\">{item.visitante}</span>\n                  </div>\n\n                </div>\n\n                {/* Obtained Points badge info on foot */}\n                <div className=\"flex justify-center\">\n                  <div className={`px-4 py-1 rounded-full font-mono text-xs font-bold border ${item.puntosColor}`}>\n                    {item.puntosLabel}\n                  </div>\n                </div>\n\n              </div>\n            );\n          })}\n        </div>\n      </section>\n\n    </div>\n  );\n}\n"
    }
