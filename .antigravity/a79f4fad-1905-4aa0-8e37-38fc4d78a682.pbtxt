  file_change {
    absolute_path_uri: "file:///src/components/SplashLogin.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \'react\';\n\ninterface SplashLoginProps {\n  onLoginSuccess: (nombre: string, email: string, whatsapp: string, codigoGrupo: string) => void;\n}\n\nexport default function SplashLogin({ onLoginSuccess }: SplashLoginProps) {\n  const [codigoGrupo, setCodigoGrupo] = useState(\'\');\n  const [googleEmail, setGoogleEmail] = useState(\'lfalzatel@gmail.com\');\n  const [showWhatsAppModal, setShowWhatsAppModal] = useState(false);\n  const [whatsappNumber, setWhatsappNumber] = useState(\'\');\n  const [errorText, setErrorText] = useState(\'\');\n\n  const handleGoogleLoginAttempt = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!codigoGrupo.trim()) {\n      setErrorText(\'Por favor ingresa un c\303\263digo de acceso de grupo.\');\n      return;\n    }\n    setErrorText(\'\');\n    setShowWhatsAppModal(true);\n  };\n\n  const handleWhatsAppSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!whatsappNumber.trim() || whatsappNumber.length < 7) {\n      setErrorText(\'Por favor ingresa un n\303\272mero de tel\303\251fono v\303\241lido.\');\n      return;\n    }\n    // Success flow!\n    onLoginSuccess(\'Santiago Vel\303\241squez\', googleEmail, \'+57 \' + whatsappNumber, codigoGrupo.toUpperCase());\n  };\n\n  return (\n    <div className=\"relative min-h-screen w-full flex items-center justify-center overflow-y-auto px-4 py-8 z-10\">\n      {/* Background Layer with Stadium mesh & light gradient overlay */}\n      <div className=\"fixed inset-0 -z-10 bg-gradient-to-b from-[#001b44]/80 via-[#121316] to-[#121316]\"></div>\n      <div className=\"fixed inset-0 -z-10 stadium-mesh opacity-40\"></div>\n\n      {/* Main Entry Panel */}\n      <div className={`relative w-full max-w-[400px] flex flex-col items-center transition-all duration-300 ${showWhatsAppModal ? \'blur-md scale-95 opacity-50\' : \'opacity-100\'}`}>\n        \n        {/* Brand logo & title */}\n        <div className=\"mb-8 text-center animate-float\">\n          <div className=\"relative inline-block mb-4\">\n            <div className=\"absolute inset-0 bg-[#79ff5b]/20 blur-2xl rounded-full\"></div>\n            <div className=\"relative w-28 h-28 flex items-center justify-center bg-[#1f1f23] rounded-full border-2 border-[#79ff5b] shadow-[0_0_30px_rgba(121,255,91,0.3)]\">\n              <span className=\"material-symbols-outlined text-[56px] text-[#79ff5b]\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                sports_soccer\n              </span>\n            </div>\n          </div>\n          <h1 className=\"font-display text-5xl text-[#e3e2e6] tracking-wider mb-2 leading-none\">\n            POLLA MUNDIALISTA FOE\n          </h1>\n          <p className=\"font-mono text-xs text-[#b1c6f9] tracking-widest uppercase\">\n            Elite Prediction League\n          </p>\n        </div>\n\n        {/* Login interactive card */}\n        <div className=\"w-full glass-panel rounded-2xl p-6 flex flex-col gap-5 shadow-2xl\">\n          <form onSubmit={handleGoogleLoginAttempt} className=\"space-y-4\">\n            <div className=\"flex flex-col gap-2\">\n              <label id=\"acceso-label-id\" className=\"font-mono text-xs text-[#c5c6d0] px-1 uppercase tracking-wider block\">\n                C\303\263digo de Acceso (Grupo)\n              </label>\n              \n              <div className=\"relative group\">\n                <span className=\"material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#8e9099] group-focus-within:text-[#79ff5b] transition-colors\">\n                  group\n                </span>\n                <input\n                  id=\"group-input-id\"\n                  className=\"w-full bg-[#292a2d] border border-white/10 focus:border-[#79ff5b] focus:ring-1 focus:ring-[#79ff5b] rounded-xl py-3.5 pl-11 pr-4 font-mono text-sm text-[#e3e2e6] placeholder-[#8e9099]/80 transition-all outline-none\"\n                  placeholder=\"EJ: CHAMPIONS-2024\"\n                  type=\"text\"\n                  value={codigoGrupo}\n                  onChange={(e) => setCodigoGrupo(e.target.value)}\n                />\n              </div>\n            </div>\n\n            {errorText && !showWhatsAppModal && (\n              <p className=\"text-red-400 text-xs font-semibold px-2 animate-pulse\">\n                {errorText}\n              </p>\n            )}\n\n            {/* Simulated Authenticator credentials default preview */}\n            <div className=\"text-center text-[11px] text-[#8e9099] bg-white/5 rounded-lg py-2 px-3 flex justify-between\">\n              <span>Google Account:</span>\n              <span className=\"text-[#b1c6f9] font-mono\">{googleEmail}</span>\n            </div>\n\n            {/* Submit button mimicking google auth */}\n            <button\n              id=\"submit-google-login-btn\"\n              type=\"submit\"\n              className=\"w-full bg-[#e3e2e6] hover:bg-white text-[#121316] font-display text-xl py-3.5 rounded-xl flex items-center justify-center gap-3 transition-all active:scale-[0.98] glow-green cursor-pointer font-bold duration-300\"\n            >\n              <svg className=\"w-5 h-5 flex-shrink-0\" viewBox=\"0 0 24 24\">\n                <path d=\"M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z\" fill=\"#4285F4\"></path>\n                <path d=\"M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z\" fill=\"#34A853\"></path>\n                <path d=\"M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z\" fill=\"#FBBC05\"></path>\n                <path d=\"M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 12-4.53z\" fill=\"#EA4335\"></path>\n              </svg>\n              <span>Login con Google</span>\n            </button>\n          </form>\n\n          <p className=\"text-center font-sans text-sm text-[#8e9099] mt-2\">\n            \302\277No tienes grupo?{\' \'}\n            <a href=\"https://wa.me/573000000000\" target=\"_blank\" rel=\"noreferrer\" className=\"text-[#b1c6f9] hover:underline font-semibold leading-relaxed\">\n              Contactar Admin\n            </a>\n          </p>\n        </div>\n\n        {/* Decorative stats */}\n        <div className=\"mt-8 flex gap-8 opacity-75\">\n          <div className=\"flex flex-col items-center\">\n            <span className=\"font-display text-4xl text-[#79ff5b]\">12k+</span>\n            <span className=\"font-mono text-[10px] uppercase tracking-wider text-[#8e9099]\">Jugadores</span>\n          </div>\n          <div className=\"w-[1px] bg-white/10 h-10 self-center\"></div>\n          <div className=\"flex flex-col items-center\">\n            <span className=\"font-display text-4xl text-[#ffe16d]\">\360\237\217\206</span>\n            <span className=\"font-mono text-[10px] uppercase tracking-wider text-[#8e9099]\">Grandes Premios</span>\n          </div>\n        </div>\n      </div>\n\n      {/* WhatsApp Modal Dialog (Renders as persistent overlay) */}\n      {showWhatsAppModal && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n          <div className=\"absolute inset-0 bg-black/85 backdrop-blur-md\"></div>\n          <div className=\"relative w-full max-w-[360px] glass-panel rounded-2xl p-6 flex flex-col gap-5 shadow-[0_0_50px_rgba(0,0,0,0.6)] animate-in fade-in zoom-in duration-300\">\n            \n            <div className=\"flex justify-between items-start\">\n              <div className=\"w-12 h-12 rounded-full bg-[#79ff5b]/10 flex items-center justify-center text-[#79ff5b]\">\n                <span className=\"material-symbols-outlined\" style={{ fontVariationSettings: \"\'FILL\' 1\" }}>\n                  chat\n                </span>\n              </div>\n              <button \n                onClick={() => setShowWhatsAppModal(false)}\n                className=\"text-[#8e9099] hover:text-[#e3e2e6] transition-colors p-1\"\n                aria-label=\"Cerrar modal\"\n              >\n                <span className=\"material-symbols-outlined\">close</span>\n              </button>\n            </div>\n\n            <div className=\"space-y-1\">\n              <h2 className=\"font-display text-3xl text-[#e3e2e6] leading-none\">PASO FINAL</h2>\n              <p className=\"font-sans text-sm text-[#c5c6d0] leading-snug\">\n                Ingresa tu WhatsApp para continuar y recibir notificaciones de tus partidos en tiempo real.\n              </p>\n            </div>\n\n            <form onSubmit={handleWhatsAppSubmit} className=\"space-y-4\">\n              <div className=\"flex flex-col gap-2\">\n                <div className=\"relative\">\n                  <span className=\"absolute left-3 top-1/2 -translate-y-1/2 font-mono text-sm text-[#8e9099] border-r border-[#8e9099]/30 pr-2\">\n                    +57\n                  </span>\n                  <input\n                    required\n                    className=\"w-full bg-[#292a2d] border border-white/10 focus:border-[#79ff5b] focus:ring-1 focus:ring-[#79ff5b] rounded-xl py-3.5 pl-15 pr-4 font-mono text-sm text-[#e3e2e6] placeholder-[#8e9099]/40 outline-none\"\n                    placeholder=\"300 000 0000\"\n                    type=\"tel\"\n                    value={whatsappNumber}\n                    onChange={(e) => setWhatsappNumber(e.target.value)}\n                  />\n                </div>\n              </div>\n\n              {errorText && (\n                <p className=\"text-red-400 text-xs font-semibold animate-pulse px-1\">\n                  {errorText}\n                </p>\n              )}\n\n              <button\n                type=\"submit\"\n                className=\"w-full bg-[#2ff801] hover:brightness-110 text-[#053900] font-bold py-3.5 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-[0.98] shadow-lg shadow-[#0f6d00]/20 cursor-pointer text-lg uppercase\"\n              >\n                <span>COMENZAR</span>\n                <span className=\"material-symbols-outlined font-bold\">arrow_forward</span>\n              </button>\n            </form>\n\n            <p className=\"text-[10px] text-center text-[#8e9099] font-mono uppercase tracking-tighter leading-tight mt-1\">\n              Al continuar aceptas recibir alertas de juego v\303\255a WhatsApp\n            </p>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
    }
